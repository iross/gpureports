FROM python:3.13-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Install dependencies (layer-cached independently of app code)
COPY pyproject.toml uv.lock ./
RUN uv sync --no-install-project --frozen

# Copy only what the dashboard needs at runtime
COPY gpu_utils.py device_name_mappings.py ./
COPY dashboard/ ./dashboard/

EXPOSE 8051

CMD ["uv", "run", "uvicorn", "dashboard.server:app", "--host", "0.0.0.0", "--port", "8051"]
